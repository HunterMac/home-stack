{
  "user": "",
  "timezone": "Europe/Warsaw",
  "puid": null,
  "pgid": null,

  "storage": {
    "root": "/srv/docker",
    "phase": 1,
    "device": ""
  },

  "network": {
    "domainSuffix": "local",
    "tls": "internal"
  },

  "installed": [],

  "backup": {
